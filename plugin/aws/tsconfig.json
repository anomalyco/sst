{
  "$schema": "https://json.schemastore.org/tsconfig",
  "compilerOptions": {
    "skipLibCheck": true,
    "declaration": true,
    "outDir": "dist",
    "target": "ES2023",
    "module": "NodeNext",
    "moduleResolution": "nodenext",
    "typeRoots": [
      "./node_modules/@types"
    ]
  },
  "include": [
    "src"
  ]
}
